# ----------------------------------------------------------------------------
# AI Resume Screener - Environment Configuration
# Copy this file to `.env` and adjust values as needed.
# The stack runs fully without an OpenAI key (it falls back to a local model).
# ----------------------------------------------------------------------------

# --- General ---
PROJECT_NAME="AI Resume Screener"
ENVIRONMENT=development
DEBUG=true

# --- Backend / API ---
API_PORT=8000
SECRET_KEY=change-me-super-secret-key-please-rotate
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (Postgres + pgvector) ---
POSTGRES_USER=ats
POSTGRES_PASSWORD=ats_password
POSTGRES_DB=ats
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL is derived from the parts above inside the app, but can be overridden:
# DATABASE_URL=postgresql+psycopg://ats:ats_password@db:5432/ats

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI Provider ---
# ai_provider: "auto" (use OpenAI if key present else local), "openai", or "local"
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Embedding dimension. OpenAI text-embedding-3-small=1536, local MiniLM=384.
# Keep in sync with the active provider; "auto" resolves this automatically.
EMBEDDING_DIM=384
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- File storage ---
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=20

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=120

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api
FRONTEND_PORT=5173
